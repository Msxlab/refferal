// Refearn veri modeli — docs/SPEC.md Bolum 6.
// Kurallar:
// - Tum tutarlar BIGINT integer cent; oranlar bps (10000 = %100).
// - Tenant-scoped tablolarda tenant_id + index.
// - ledger_entries SILINMEZ; guncellenen tek alanlar status/payout_id.
// - memberships.path: ltree-uyumlu TEXT (uuid'ler _ ile), yerlesim DEGISTIRILEMEZ.
//   ltree extension migration'da aktif (docs/DECISIONS.md).

generator client {
  provider = "prisma-client-js"
  // native = lokal gelistirme (Windows); debian-openssl-3.0.x = Docker runtime (bookworm)
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  platform_admin
  tenant_owner
  tenant_admin
  tenant_staff
  member
}

enum TenantStatus {
  active
  suspended
}

enum MembershipStatus {
  active
  inactive
}

enum InviteStatus {
  active
  used
  expired
  revoked
}

enum MaturationRule {
  on_approval
  on_delivery
  days_after_approval
  // teslimden N gun sonra olgunlasir (iade penceresi): pencere kapanana dek pending kalir
  days_after_delivery
}

enum SaleStatus {
  draft
  approved
  void
}

enum LedgerType {
  commission
  reversal
  adjustment
}

enum CampaignMetric {
  revenue       // pencere icindeki onayli satis cirosu (satici bazinda)
  sales_count   // onayli satis adedi
  new_recruits  // pencere icinde katilan, bu uyenin sponsorlugundaki uyeler
  invites       // pencere icinde olusturulan davetler
}

enum CampaignStatus {
  draft
  active
  ended
}

enum PayoutProfileStatus {
  unverified
  pending_review
  verified
  rejected
}

enum TaxIdType {
  ssn // bireysel (W-9)
  ein // isletme
}

enum BankAccountType {
  checking
  savings
}

enum FraudStatus {
  open      // inceleme bekliyor (payout bloklu)
  cleared   // temize cikti (payout serbest)
  confirmed // dolandiricilik teyitli (payout bloklu kalir)
}

enum LedgerStatus {
  pending
  payable
  paid
  reversed
}

enum PayoutMethod {
  manual
  csv
  stripe
}

enum PayoutStatus {
  requested
  processing
  paid
  failed
}

enum NotificationChannel {
  push
  email
  in_app
}

enum NotificationStatus {
  pending
  sent
  failed
}

model Tenant {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String         @unique
  name                String
  currency            String         @default("USD")
  timezone            String         @default("America/New_York")
  maturationRule      MaturationRule @default(on_delivery) @map("maturation_rule")
  maturationDays      Int?           @map("maturation_days")
  payoutMinCents      BigInt         @default(100000) @map("payout_min_cents")
  compressionEnabled  Boolean        @default(false) @map("compression_enabled")
  inactiveMembersEarn Boolean        @default(true) @map("inactive_members_earn")
  notifyNewMemberName Boolean        @default(true) @map("notify_new_member_name")
  // Gorevler ayrimi (maker-checker): satisi giren onaylayamaz. Varsayilan kapali
  // (tek-admin tenant'lari kirmasin); kapali iken self-onay audit'te isaretlenir.
  requireSeparateApprover Boolean    @default(false) @map("require_separate_approver")
  // KYC kapisi: acikken payout yalniz 'verified' odeme profili + soguma suresi gecmisse acilir.
  requireKycForPayout Boolean        @default(false) @map("require_kyc_for_payout")
  branding            Json           @default("{}")
  status              TenantStatus   @default(active)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  memberships Membership[]
  invites     Invite[]
  plans       CommissionPlan[]
  sales       Sale[]
  ledger      LedgerEntry[]
  summaries   MonthlySummary[]
  teamStats   TeamStat[]
  payouts     Payout[]
  roles       TenantRole[]
  campaigns   Campaign[]
  savedViews  SavedView[]
  payoutProfiles PayoutProfile[]
  fraudFlags  FraudFlag[]
  surveys     SurveyResponse[]
  inviteEvents InviteEvent[]

  @@map("tenants")
}

// RBAC: kiracci-kapsamli roller. Sistem rolleri (isSystem) silinemez/yeniden adlandirilamaz;
// ozel roller serbestce duzenlenir. permissions = izin-anahtari dizisi (kod katalogu, common/permissions.ts).
// tenant_owner enum katmani her zaman tum izinleri tasir (god-mode), roleId'den bagimsiz.
model TenantRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  key         String
  name        String
  description String?
  color       String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  fullName        String    @map("full_name")
  avatarPath      String?   @map("avatar_path")
  locale          String    @default("en")
  emailVerifiedAt DateTime? @map("email_verified_at")
  // Platform sahibi (Axtra): kiracci-ustu; sirketleri yonetir, uyelik gerektirmez.
  isPlatformAdmin Boolean   @default(false) @map("is_platform_admin")
  // 2FA: TOTP gizli anahtari (kayit asamasinda yazilir, enable'da dogrulanir).
  totpSecret      String?   @map("totp_secret")
  totpEnabledAt   DateTime? @map("totp_enabled_at")
  // Tek kullanimlik kurtarma kodlari — yalniz sha256 hash dizisi saklanir.
  mfaRecoveryCodes Json?    @map("mfa_recovery_codes")
  // "son secim hatirlanir" (SPEC 4.1): coklu uyelikte aktif tenant secimi
  lastMembershipId String?  @map("last_membership_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships   Membership[]
  devices       Device[]
  refreshTokens RefreshToken[]
  userTokens    UserToken[]

  @@map("users")
}

// Rotasyonlu refresh token (SPEC 5): DB'de yalnizca SHA-256 hash saklanir.
// Reuse detection: revoke edilmis token sunulursa kullanicinin tum token'lari iptal edilir.
model RefreshToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  ip           String?
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum UserTokenPurpose {
  email_verify
  password_reset
  login_otp
}

// E-posta dogrulama / sifre sifirlama token'lari (tek kullanimlik, hash'li)
model UserToken {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  purpose   UserTokenPurpose
  tokenHash String           @unique @map("token_hash")
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("user_tokens")
}

model Membership {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  // Kaba yetki katmani (auth/scope): platform/tenant ayrimi + owner god-mode bu enum'a bagli.
  role                Role             @default(member)
  // Ince yetki: atanmis ozel rol (izin matrisi). Yoksa enum katmaninin varsayilan izinleri uygulanir.
  roleId              String?          @map("role_id") @db.Uuid
  sponsorMembershipId String?          @map("sponsor_membership_id") @db.Uuid
  referralCode        String           @map("referral_code")
  // ltree-uyumlu materialized path: parent.path || own_id (uuid'ler _ ile). DEGISTIRILEMEZ.
  path                String
  depth               Int
  status              MembershipStatus @default(active)
  // Sybil tespiti (#16): kayit anindaki IP. Ayni IP'den N+ uye → fraud sinyali.
  signupIp            String?          @map("signup_ip")
  // Kanal bazli bildirim tercihleri: { "<event>": { in_app, email, push } } — bos = varsayilanlar.
  notificationPrefs   Json             @default("{}") @map("notification_prefs")
  joinedAt            DateTime         @default(now()) @map("joined_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  user     User         @relation(fields: [userId], references: [id])
  roleRef  TenantRole?  @relation(fields: [roleId], references: [id])
  sponsor  Membership?  @relation("SponsorTree", fields: [sponsorMembershipId], references: [id])
  children Membership[] @relation("SponsorTree")

  invitesSent Invite[]         @relation("Inviter")
  sales       Sale[]           @relation("Seller")
  ledger      LedgerEntry[]    @relation("Beneficiary")
  summaries   MonthlySummary[]
  teamStats   TeamStat[]
  payouts     Payout[]
  payoutProfile PayoutProfile?
  fraudFlag   FraudFlag?

  @@unique([tenantId, userId])
  @@unique([tenantId, referralCode])
  @@index([tenantId, sponsorMembershipId])
  @@index([tenantId, path])
  @@map("memberships")
}

model Invite {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String       @map("tenant_id") @db.Uuid
  inviterMembershipId String       @map("inviter_membership_id") @db.Uuid
  code                String       @unique
  email               String?
  expiresAt           DateTime     @map("expires_at")
  usedByMembershipId  String?      @map("used_by_membership_id") @db.Uuid
  status              InviteStatus @default(active)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  tenant  Tenant     @relation(fields: [tenantId], references: [id])
  inviter Membership @relation("Inviter", fields: [inviterMembershipId], references: [id])
  events  InviteEvent[]

  @@index([tenantId, status])
  @@map("invites")
}

// Davet funnel (#14): tiklama/goruntuleme event'i + UTM kanal kaynagi. signup = Invite.used'tan turetilir.
model InviteEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  inviteId  String   @map("invite_id") @db.Uuid
  event     String   // 'view'
  utmSource String?  @map("utm_source")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invite Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("invite_events")
}

model CommissionPlan {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  poolRateBps   Int      @map("pool_rate_bps")
  depth         Int
  effectiveFrom DateTime @map("effective_from")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  levels CommissionPlanLevel[]

  // Tarihsel sorgu: satis tarihinde aktif plan (effective_from <= sale_date, en yeni)
  @@index([tenantId, effectiveFrom(sort: Desc)])
  @@map("commission_plans")
}

model CommissionPlanLevel {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId    String   @map("plan_id") @db.Uuid
  level     Int
  rateBps   Int      @map("rate_bps")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plan CommissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // SUM(rate_bps) <= pool_rate_bps kurali migration'daki constraint trigger ile zorlanir
  @@unique([planId, level])
  @@map("commission_plan_levels")
}

model Sale {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String     @map("tenant_id") @db.Uuid
  sellerMembershipId String     @map("seller_membership_id") @db.Uuid
  amountCents        BigInt     @map("amount_cents")
  currency           String     @default("USD")
  customerRef        String?    @map("customer_ref")
  createdBy          String?    @map("created_by") @db.Uuid
  saleDate           DateTime   @map("sale_date")
  // monthly_summaries ay anahtari ilk apply'da DONDURULUR (tenant.timezone sonradan
  // degisse bile kredi/dusum ayni bucket'a gider — bkz. DECISIONS "Inceleme bulgulari").
  summaryMonth       String?    @map("summary_month")
  status             SaleStatus @default(draft)
  approvedBy         String?    @map("approved_by") @db.Uuid
  approvedAt         DateTime?  @map("approved_at")
  deliveredAt        DateTime?  @map("delivered_at")
  externalRef        String?    @map("external_ref")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  seller Membership    @relation("Seller", fields: [sellerMembershipId], references: [id])
  ledger LedgerEntry[]

  @@index([tenantId, status])
  @@index([tenantId, saleDate])
  @@map("sales")
}

model LedgerEntry {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String       @map("tenant_id") @db.Uuid
  // Satisa bagli komisyon/reversal'da dolu; kampanya bonusu/manuel ayarlama gibi
  // satisa bagli OLMAYAN satirlarda NULL (o satirlar summaryMonth'u kendileri tasir).
  saleId                  String?      @map("sale_id") @db.Uuid
  beneficiaryMembershipId String       @map("beneficiary_membership_id") @db.Uuid
  level                   Int
  rateBpsUsed             Int          @map("rate_bps_used")
  amountCents             BigInt       @map("amount_cents")
  type                    LedgerType
  status                  LedgerStatus
  // Satisa bagli olmayan satirin ay bucket'i (payout/summary icin). Komisyonda NULL
  // kalir, ay sale.summary_month'tan turetilir (geriye donuk uyumlu).
  summaryMonth            String?      @map("summary_month")
  maturesAt               DateTime?    @map("matures_at")
  payoutId                String?      @map("payout_id") @db.Uuid
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  sale        Sale?      @relation(fields: [saleId], references: [id])
  beneficiary Membership @relation("Beneficiary", fields: [beneficiaryMembershipId], references: [id])
  // Restrict: payout silinince 'paid' satirin payout_id'si sessizce NULL olmasin
  // (ledger degismezligi — bkz. DECISIONS "Inceleme bulgulari").
  payout      Payout?    @relation(fields: [payoutId], references: [id], onDelete: Restrict)

  // Cift odeme imkansiz: motor kac kez cagrilirsa cagrilsin ayni sonuc.
  // (saleId NULL satirlar Postgres'te bu kisitta birbirinden ayri sayilir — bonuslar etkilenmez.)
  @@unique([saleId, level, type])
  @@index([tenantId, beneficiaryMembershipId, status])
  @@index([status, maturesAt])
  @@map("ledger_entries")
}

model MonthlySummary {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  // Tenant timezone'una gore YYYY-MM (SPEC 10 — Zaman)
  month        String
  level        Int
  pendingCents BigInt   @default(0) @map("pending_cents")
  payableCents BigInt   @default(0) @map("payable_cents")
  paidCents    BigInt   @default(0) @map("paid_cents")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  membership Membership @relation(fields: [membershipId], references: [id])

  @@unique([tenantId, membershipId, month, level])
  @@index([tenantId, month])
  @@map("monthly_summaries")
}

model TeamStat {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  level        Int
  memberCount  Int      @default(0) @map("member_count")
  activeCount  Int      @default(0) @map("active_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  membership Membership @relation(fields: [membershipId], references: [id])

  @@unique([tenantId, membershipId, level])
  @@map("team_stats")
}

model Payout {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  membershipId String       @map("membership_id") @db.Uuid
  totalCents   BigInt       @map("total_cents")
  method       PayoutMethod @default(manual)
  status       PayoutStatus @default(requested)
  // Donem: YYYY-MM (aylik, docs/DECISIONS.md)
  period       String
  paidAt       DateTime?    @map("paid_at")
  ref          String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  membership Membership    @relation(fields: [membershipId], references: [id])
  entries    LedgerEntry[]

  @@index([tenantId, status])
  @@map("payouts")
}

model Device {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  expoPushToken String   @unique @map("expo_push_token")
  platform      String
  lastSeenAt    DateTime @default(now()) @map("last_seen_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

// Outbox (SPEC 5): transaction icinde yazilir, BullMQ worker asenkron gonderir
model Notification {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String?             @map("tenant_id") @db.Uuid
  recipientMembershipId String              @map("recipient_membership_id") @db.Uuid
  channel               NotificationChannel
  template              String
  payload               Json                @default("{}")
  status                NotificationStatus  @default(pending)
  attempts              Int                 @default(0)
  lastError             String?             @map("last_error")
  sentAt                DateTime?           @map("sent_at")
  // in_app kanali: gelen kutusunda okundu durumu (diger kanallarda null kalir).
  readAt                DateTime?           @map("read_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([recipientMembershipId, channel, readAt])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entity      String
  entityId    String?  @map("entity_id") @db.Uuid
  before      Json?
  after       Json?
  ip          String?
  // Kurcalamaya-dayanikli zincir: seal job'i kayitlari createdAt sirasiyla hash'ler
  // (hash = sha256(prevHash + kanonik icerik)). Tek satir oynanirsa zincir kirilir.
  prevHash    String?  @map("prev_hash")
  hash        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// Referans yarismasi / kampanya: zaman sinirli yaris, donem sonu bonus odulu.
// Siralama CANLI hesaplanir (sales/memberships/invites'tan); finalize aninda kazananlar
// 'results' jsonb'sine donderilir ve oduller ledger'a 'adjustment' (payable) satiri olarak
// yazilir (engine.awardBonus) — normal payout akisindan odenir.
model Campaign {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  name        String
  description String?
  metric      CampaignMetric
  startsAt    DateTime       @map("starts_at")
  endsAt      DateTime       @map("ends_at")
  status      CampaignStatus @default(draft)
  // prizes: [{ rank: 1, bonusCents: 50000 }, ...] (integer cent)
  prizes      Json           @default("[]")
  // finalize sonrasi kazanan anlik goruntusu: [{ rank, membershipId, name, code, score, bonusCents }]
  results     Json?
  createdBy   String?        @map("created_by") @db.Uuid
  finalizedAt DateTime?      @map("finalized_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("campaigns")
}

// Kayitli gorunum: filtre+siralama setinin isimli kaydi. shared=true ise tum ekip gorur
// (kisisel = yalniz sahibi). config jsonb: hedefe gore { status, q, from, to, sort, dir, ... }.
model SavedView {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  target      String   // 'sales' | 'members' | ...
  name        String
  shared      Boolean  @default(false)
  config      Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, target])
  @@map("saved_views")
}

// KYC / odeme profili (ABD). GIZLILIK: tam SSN/hesap no SAKLANMAZ — yalniz son-4 + routing
// (public banka kimligi) + durum makinesi tutulur. Tam veri Dalga 3'te odeme saglayici
// (Stripe Connect) kasasinda olacak. Payout yalniz 'verified' + soguma suresi gecmis profille acilir.
model PayoutProfile {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  membershipId     String              @unique @map("membership_id") @db.Uuid
  legalName        String              @map("legal_name")
  country          String              @default("US")
  taxIdType        TaxIdType           @map("tax_id_type")
  taxIdLast4       String              @map("tax_id_last4")
  bankName         String?             @map("bank_name")
  routingNumber    String              @map("routing_number")
  accountType      BankAccountType     @map("account_type")
  accountLast4     String              @map("account_last4")
  status           PayoutProfileStatus @default(pending_review)
  rejectionReason  String?             @map("rejection_reason")
  // banka/kimlik degisikligi zamani — soguma suresi (anti-account-takeover) buradan olcuelur
  lastChangedAt    DateTime            @map("last_changed_at")
  reviewedByUserId String?             @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?           @map("reviewed_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("payout_profiles")
}

// Fraud sinyal motoru (#11): saatlik tarama uye basina risk skoru + sebepler uretir.
// score >= BLOCK ve status != cleared ise payout BLOKLANIR (riskli komisyon hold'u).
model FraudFlag {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String      @map("tenant_id") @db.Uuid
  membershipId     String      @unique @map("membership_id") @db.Uuid
  score            Int         @default(0)
  reasons          Json        @default("[]")
  status           FraudStatus @default(open)
  note             String?
  reviewedByUserId String?     @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime?   @map("reviewed_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("fraud_flags")
}

// NPS / mikro anket (#9): uye memnuniyeti. score 0-10; >=9 promoter, 7-8 passive, <=6 detractor.
model SurveyResponse {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  score        Int
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([membershipId, createdAt])
  @@map("survey_responses")
}
