# ============================================================================
# Lokal gelistirme (pnpm ile api/web kosarken). Kopyala: cp .env.example .env
# ============================================================================
# Postgres/Redis — host portlari 5434/6380 (bkz. docker-compose.yml)
DATABASE_URL=postgresql://refearn:refearn@localhost:5434/refearn
DATABASE_URL_TEST=postgresql://refearn:refearn@localhost:5434/refearn_test
REDIS_URL=redis://localhost:6380

# Auth — uretimde GUCLU rastgele deger (uretimde yoksa uygulama acilmaz)
JWT_ACCESS_SECRET=change-me-access

# ============================================================================
# Tam yigin (docker compose --profile app up). Sadece prod compose icin gerekli.
# ============================================================================
# Caddy alan adi. Bos/":80" → lokal (TLS yok). Gercek alan adi → otomatik HTTPS.
#   DOMAIN=refearn.example.com
DOMAIN=
# API CORS + e-posta linkleri icin public kok URL (genelde https://DOMAIN)
PUBLIC_ORIGIN=http://localhost

# SMTP (bos ise dev'de e-posta console'a yazilir)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Refearn <no-reply@refearn.local>

# Yedek (lokal)
BACKUP_RETENTION_DAYS=30

# --- Offsite: Google Drive (rclone + service account) ---
# 1) Google Cloud > Drive API > Service Account > JSON anahtar indir
#    -> docker/backup/secrets/gdrive.json olarak birak (repoya GIRMEZ)
# 2) Drive'da bir klasor olustur, service account e-postasiyla PAYLAS, klasor ID'sini buraya yaz
GDRIVE_FOLDER_ID=
# 3) Offsite komutunu ac (bos birakirsan yalniz lokal yedek alinir):
#    BACKUP_OFFSITE_CMD=rclone copyto "$1" gdrive:$(basename "$1")
BACKUP_OFFSITE_CMD=
# Yedek SIFRELEME (onerilir): age public key. Uretme: age-keygen -o age.key (public satiri buraya)
#    Private key'i (age.key) SUNUCUDA TUTMA; 1Password/Bitwarden + offline ikinci yere koy.
BACKUP_AGE_RECIPIENT=
# Yedek basarisizliginda alarm komutu (opsiyonel); $1 = mesaj
#   BACKUP_ALERT_CMD=curl -fsS -m10 --retry 3 https://hc-ping.com/<uuid>/fail -d "$1"
BACKUP_ALERT_CMD=
